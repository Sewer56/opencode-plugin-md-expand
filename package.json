{
  "name": "opencode-plugin-md-expand",
  "version": "0.1.0",
  "description": "OpenCode plugin and CLI for expanding Markdown prompt templates.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": { "opencode-plugin-md-expand": "./dist/cli.js" },
  "files": ["dist", "README.md", "LICENSE"],
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/md-expand.test.ts",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "keywords": ["opencode", "opencode-plugin", "markdown", "prompt", "templates"],
  "license": "MIT",
  "engines": { "opencode": ">=1.0.0" },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.41",
    "xdg-basedir": "^5.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^24.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
